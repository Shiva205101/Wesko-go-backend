# Copy the values you need into configs/.env.config for local development.
ENV=local
HTTP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_USER=
GOOGLE_CLIENT_ID=change-me.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
TWILIO_ACCOUNT_SID=
TWILIO_VERIFY_SERVICE_SID=
