# Shared Cloud Run configuration.
HTTP_PORT=8080
DB_SSL_MODE=require
DB_DEBUG=false
AUTH_ISSUER=wesko
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_NAME=wesko_refresh_token
AUTH_COOKIE_PATH=/auth
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_CSRF_COOKIE_NAME=wesko_csrf_token
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_CSRF_COOKIE_PATH=/auth
AUTH_CSRF_COOKIE_SECURE=true
AUTH_CSRF_COOKIE_SAME_SITE=lax
AUTH_PENDING_SIGNUP_TTL_SECONDS=600
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_RESENDS=5
AUTH_OTP_REQUEST_LIMIT_IP=10
AUTH_OTP_REQUEST_LIMIT_WINDOW_SECONDS=600
AUTH_OTP_REQUEST_LIMIT_MOBILE=3
AUTH_OTP_VERIFY_LIMIT_IP=20
AUTH_OTP_VERIFY_LIMIT_WINDOW_SECONDS=600
AUTH_OTP_VERIFY_LIMIT_MOBILE=5
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=300
REDIS_DIAL_TIMEOUT_SECONDS=5
REDIS_READ_TIMEOUT_SECONDS=1
REDIS_WRITE_TIMEOUT_SECONDS=2
REDIS_POOL_TIMEOUT_MILLISECONDS=500
