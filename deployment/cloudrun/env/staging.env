ENV=staging
HTTP_ALLOWED_ORIGINS=https://staging.wesko.example.com
CLOUD_SQL_CONNECTION_NAME=change-me-project:asia-south1:change-me-instance
VPC_CONNECTOR=change-me-staging-connector
VPC_EGRESS=private-ranges-only
VPC_NETWORK=default
VPC_SUBNET=change-me-asia-south1-subnet
REDIS_HOST=change-me-staging-redis-host
REDIS_USER=
GOOGLE_CLIENT_ID=change-me-staging-google-client-id
GOOGLE_REDIRECT_URI=https://staging-api.wesko.example.com/auth/google/callback
TWILIO_ACCOUNT_SID=
TWILIO_VERIFY_SERVICE_SID=
